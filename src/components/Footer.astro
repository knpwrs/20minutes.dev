// Site footer ported from Landing.dc.html.
---

<footer class="border-t border-white/10">
	<div
		class="mx-auto flex max-w-[1180px] flex-wrap items-center justify-between gap-4 px-[clamp(20px,5vw,40px)] py-8"
	>
		<a href="/" class="font-mono text-[13px] text-faint hover:text-muted-2">
			20minutes<span class="text-accent">.dev</span>
		</a>
		<div class="flex flex-wrap items-center gap-x-5 gap-y-1.5">
			<span class="font-display text-[13px] font-medium text-faint">
				Staying grounded in real code in the age of AI.
			</span>
			<a
				href="https://creativecommons.org/publicdomain/zero/1.0/"
				target="_blank"
				rel="noopener"
				class="font-mono text-[12.5px] text-faint hover:text-muted-2"
				title="This site's content is dedicated to the public domain under CC0 1.0"
			>
				Content is CC0 (public domain)
			</a>
		</div>
	</div>
</footer>
