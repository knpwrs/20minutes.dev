---
import type { Project } from '../data/projects';

interface Props {
	project: Project;
	/** When true, the meta line includes the estimated minutes per lesson. */
	showEstMin?: boolean;
}

const { project, showEstMin = false } = Astro.props;
---

<a
	href={`/projects/${project.slug}`}
	data-size={project.size}
	class="group flex flex-col rounded-card border border-white/10 bg-surface p-6 pb-[22px] transition duration-200 ease-out hover:-translate-y-[3px] hover:border-white/20 hover:shadow-[0_18px_40px_-22px_rgba(0,0,0,.55)]"
>
	<div class="mb-[18px] flex items-center justify-between gap-3">
		<span class="font-mono text-xs text-faint">
			{project.lessons} lessons{showEstMin && ` · ~${project.estMin} min/lesson`}
		</span>
		<span
			class="rounded-md border border-accent/30 bg-accent/[0.08] px-[9px] py-[3px] font-mono text-[11px] tracking-[0.04em] text-accent"
		>
			{project.size}
		</span>
	</div>
	<h3 class="mb-2.5 font-display text-[22px] font-semibold tracking-[-0.02em] text-fg">
		{project.title}
	</h3>
	<p class="mb-5 flex-1 text-sm leading-[1.55] text-[#a4a8b0]">{project.desc}</p>
	<div class="flex flex-wrap gap-[7px]">
		{
			project.tech.map((t) => (
				<span class="rounded-[5px] bg-chip px-2 py-[3px] font-mono text-[11.5px] text-dim">{t}</span>
			))
		}
	</div>
</a>
