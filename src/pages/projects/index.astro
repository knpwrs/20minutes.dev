---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getAllProjects } from '../../data/projects';

const projects = await getAllProjects();
const filters = ['All', 'Small', 'Medium', 'Large'] as const;
---

<Layout
	title="Projects - 20minutes.dev"
	description="Every project is a sequence of short lessons - each a concrete spec you make work - that ends in a real program."
>
	<div class="flex min-h-screen w-full flex-col overflow-x-hidden">
		<Nav active="projects" ctaHref="/projects/build-a-database" />

		<!-- ===== HEADER ===== -->
		<header
			class="mx-auto w-full max-w-295 px-[clamp(20px,5vw,40px)] pt-[clamp(48px,7vw,80px)] pb-8.5"
		>
			<div class="mb-3.5 font-mono text-xs uppercase tracking-[0.14em] text-accent">Projects</div>
			<h1
				class="mb-4.5 max-w-180 font-display text-[clamp(34px,5.5vw,52px)] font-semibold leading-[1.05] tracking-[-0.03em] text-fg"
			>
				Everything you can build.
			</h1>
			<p class="max-w-140 text-[clamp(16px,2vw,18px)] leading-[1.6] text-muted">
				Each project is a sequence of short lessons that ends in a working program. Pick one that
				you've always wanted to understand from the inside.
			</p>

			<!-- filter -->
			<div class="mt-8.5 flex flex-wrap items-center gap-2.5" data-filter-bar>
				<span
					class="mr-1 font-mono text-[11.5px] uppercase tracking-[0.06em] text-faint"
				>
					Size
				</span>
				{
					filters.map((f) => (
						<button
							type="button"
							data-filter={f}
							aria-pressed={f === 'All' ? 'true' : 'false'}
							class="cursor-pointer rounded-full border px-3.75 py-1.75 font-display text-[13.5px] font-semibold transition duration-150 aria-pressed:border-accent aria-pressed:bg-accent aria-pressed:text-ink border-white/16 bg-transparent text-muted hover:border-white/30"
						>
							{f}
						</button>
					))
				}
				<span class="ml-auto font-mono text-xs text-faint" data-count>
					{projects.length} projects
				</span>
			</div>
		</header>

		<!-- ===== GRID ===== -->
		<section class="mx-auto w-full max-w-295 flex-1 px-[clamp(20px,5vw,40px)] pt-1.5 pb-22.5">
			<div
				class="grid gap-5 grid-cols-[repeat(auto-fill,minmax(300px,1fr))]"
				data-grid
			>
				{projects.map((project) => <ProjectCard project={project} showEstMin />)}
			</div>
			<p class="mt-8 hidden font-mono text-sm text-faint" data-empty>
				No projects of this size yet.
			</p>
		</section>

		<Footer />
	</div>
</Layout>

<script>
	// Progressive-enhancement size filter - the page is fully rendered
	// server-side; this only toggles card visibility.
	function initProjectFilter() {
		const bar = document.querySelector<HTMLElement>('[data-filter-bar]');
		const grid = document.querySelector<HTMLElement>('[data-grid]');
		if (!bar || !grid) return;

		const buttons = Array.from(bar.querySelectorAll<HTMLButtonElement>('[data-filter]'));
		const cards = Array.from(grid.querySelectorAll<HTMLElement>('[data-size]'));
		const countEl = document.querySelector<HTMLElement>('[data-count]');
		const emptyEl = document.querySelector<HTMLElement>('[data-empty]');

		function apply(active: string) {
			let shown = 0;
			for (const card of cards) {
				const match = active === 'All' || card.dataset.size === active;
				card.hidden = !match;
				if (match) shown++;
			}
			for (const b of buttons) {
				b.setAttribute('aria-pressed', String(b.dataset.filter === active));
			}
			if (countEl) countEl.textContent = `${shown} ${shown === 1 ? 'project' : 'projects'}`;
			if (emptyEl) emptyEl.hidden = shown !== 0;
		}

		for (const b of buttons) {
			b.addEventListener('click', () => apply(b.dataset.filter ?? 'All'));
		}
	}

	initProjectFilter();
</script>
