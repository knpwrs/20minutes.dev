---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = '20minutes.dev - Build real software, twenty minutes at a time',
	description =
		'Projects that build a database, a compiler, an emulator - one focused twenty-minute session at a time.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-ink">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Public+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="bg-ink text-fg">
		<slot />
	</body>
</html>
